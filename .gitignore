# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# IDEs & Editors
.idea/
*.iml
*.iws
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp

# ============================================================
# SECRETS & CREDENTIALS — never commit these
# ============================================================

# Environment variable files (all subdirectories)
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Google Cloud / Firebase service account JSON keys
# Pattern matches any file with a GCP-style project ID in the name
*-[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].json
# Explicit known key files
humequity-idp-34d21aedb5e5.json
**/humequity-idp-*.json
# Broad safety net: any file named "service-account*.json" or "credentials*.json"
service-account*.json
**/service-account*.json
credentials*.json
**/credentials*.json
secrets*.json
**/secrets*.json

# Firebase / Google Services config (Android & iOS)
google-services.json
**/google-services.json
GoogleService-Info.plist
**/GoogleService-Info.plist

# Android signing keystores & key properties
*.keystore
*.jks
**/key.properties
/mobile/android/key.properties
/mobile/android/**/*.apk
/mobile/android/**/*.aab

# iOS certificates & provisioning profiles
*.p12
*.pem
*.cer
*.mobileprovision
*.provisionprofile

# ============================================================
# Node.js (api_portal & helper)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/

# ============================================================
# Flutter / Dart (mobile)
# ============================================================
.dart_tool/
.packages
.pub-cache/
.pub/
build/
*.log

# Mobile - iOS (generated / build artefacts)
/mobile/ios/Runner/GeneratedPluginRegistrant.*
/mobile/ios/Flutter/App.framework
/mobile/ios/Flutter/Flutter.framework
/mobile/ios/Flutter/Flutter.podspec
/mobile/ios/Flutter/Generated.xcconfig
/mobile/ios/Flutter/app.flx
/mobile/ios/Flutter/app.zip
/mobile/ios/Flutter/flutter_assets/
/mobile/ios/Flutter/flutter_export_environment.sh
/mobile/ios/Pods/
/mobile/ios/.symlinks/

# Firebase
.firebase/
firebase-debug.log
